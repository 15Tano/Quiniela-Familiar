# Copia este archivo a ".env" (mismo nombre, sin ".example") y pega aquí
# las credenciales de tu proyecto de Firebase. El paso a paso completo
# está en el README, sección "Configurar la base de datos compartida".

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional: identificador del "cuarto" compartido en Firestore.
# Solo cámbialo si vas a correr más de una quiniela al mismo tiempo
# con este mismo proyecto de Firebase.
VITE_QUINIELA_ROOM=familiar
